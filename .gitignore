# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# database (contains sensitive client data - do not commit the JSON)
database/data.json

# uploaded files & media (large binaries)
public/uploads/
public/media/

# old legacy Research folder scripts & backups
public/Research/node_modules/
public/Research/package-lock.json
_backup/

# one-off fix scripts at root (only root level)
deep-fix*.js
/fix_client.js
/database.js
/admin.html
/portal.html
/server.js
/index.html
